<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Animated Site Demo</title>
  <link rel="stylesheet" href="style.css"/>

  <!-- GSAP CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
</head>

<body>

<header class="hero">
  <div class="hero-content">
    <h1 class="fade-up">Animated Slots Experience</h1>
    <p class="fade-up delay">Not boring. Not static. Not 2005.</p>
    <button class="btn fade-up delay2">Try It</button>
  </div>
</header>

<section class="section">
  <div class="card fade-in">
    <h2>Scroll Animation</h2>
    <p>This section fades in as you scroll.</p>
  </div>
</section>

<section class="section">
  <div class="card slide-in">
    <h2>Slide Effect</h2>
    <p>Elements can slide in smoothly.</p>
  </div>
</section>

<script src="script.js"></script>
</body>
</html>